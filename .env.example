# 数据库配置 - Neon PostgreSQL
# 从 https://neon.tech 获取连接字符串
# 格式: postgresql://用户名:密码@主机名/数据库名?sslmode=require
DATABASE_URL="postgresql://用户名:密码@ep-xxxxx.region.aws.neon.tech/syntax-lab?sslmode=require"

# NextAuth 配置
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="constructscape-secret-key-change-in-production-123456789"

# AI 配置（可选，也可以在应用内设置）
# AI_API_KEY="your-api-key"
# AI_BASE_URL="https://api.deepseek.com"
# AI_MODEL="deepseek-v4-pro"
